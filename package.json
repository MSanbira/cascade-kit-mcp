{
  "name": "cascade-kit-mcp",
  "version": "0.1.0",
  "description": "MCP server for CascadeKit - helps AI agents build React apps following CascadeKit conventions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "cascade-kit-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cascadekit",
    "cascade-kit",
    "ai",
    "react",
    "css",
    "ai-tools",
    "claude",
    "windsurf",
    "cursor"
  ],
  "author": "msanbira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msanbira/cascade-kit-mcp.git"
  },
  "homepage": "https://github.com/msanbira/cascade-kit-mcp#readme",
  "bugs": {
    "url": "https://github.com/msanbira/cascade-kit-mcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cascade-kit-tools": "^0.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
